% ═══════════════════════════════════════════════════════════════════
% IT Security & Compliance — Full Knowledge Base (Small)
% ═══════════════════════════════════════════════════════════════════
%
% 30 users, 50 resources, ~578 facts
% Combined from policies/ + standards/ + data/
%
% For interactive evaluation with Euclid-MCP + Ollama.
% Usage: paste this entire file as the "knowledge" parameter in reason()
%
% For the full dataset (200 users, 300 resources, ~3872 facts),
% use: examples/07_it_security_compliance/demo.py
% ═══════════════════════════════════════════════════════════════════


% ───────────────────────────────────────────────────────────────
% Layer 1: Standards
% ───────────────────────────────────────────────────────────────

% ── CIS Amazon Web Services Foundations Benchmark ──

cis_control(cis_1_1, 'Maintain separate AWS accounts', high)
cis_control(cis_1_2, 'Use organizations for multi-account', medium)
cis_control(cis_1_3, 'Use SCPs to restrict account usage', medium)
cis_control(cis_1_4, 'Do not use root account for daily tasks', critical)
cis_control(cis_1_5, 'Create individual IAM users', high)
cis_control(cis_1_6, 'Use IAM groups for user management', medium)
cis_control(cis_1_7, 'Use strong password policy', high)
cis_control(cis_1_8, 'Enable MFA for all IAM users', critical)
cis_control(cis_1_9, 'Rotate access keys every 90 days', high)
cis_control(cis_1_10, 'Do not create access keys for root', critical)
cis_control(cis_1_11, 'Use MFA for root account', critical)

cis_control(cis_2_1, 'Enable S3 bucket versioning', medium)
cis_control(cis_2_2, 'Enable S3 bucket logging', high)
cis_control(cis_2_3, 'Ensure S3 buckets are not publicly accessible', critical)
cis_control(cis_2_4, 'Ensure S3 bucket policies deny HTTP', high)
cis_control(cis_2_5, 'Restrict S3 bucket policies to known principals', high)
cis_control(cis_2_6, 'Enable EBS encryption by default', high)
cis_control(cis_2_7, 'Enable RDS encryption', critical)
cis_control(cis_2_8, 'Enable RDS automated backups', high)
cis_control(cis_2_9, 'Restrict S3 access to specific VPC endpoints', medium)

cis_control(cis_3_1, 'Enable CloudTrail in all regions', critical)
cis_control(cis_3_2, 'Enable CloudTrail log file validation', high)
cis_control(cis_3_3, 'Ensure CloudTrail logs are stored in S3', high)
cis_control(cis_3_4, 'Enable CloudTrail for global services', high)
cis_control(cis_3_5, 'Enable VPC Flow Logs', high)
cis_control(cis_3_6, 'Enable ALB access logging', medium)
cis_control(cis_3_7, 'Enable ELB connection draining', medium)
cis_control(cis_3_8, 'Ensure CloudWatch alarms for root login', critical)

cis_control(cis_4_1, 'Ensure no unrestricted security groups (0.0.0.0/0)', critical)
cis_control(cis_4_2, 'Restrict SSH access (port 22) to known IPs', critical)
cis_control(cis_4_3, 'Restrict RDP access (port 3389) to known IPs', critical)
cis_control(cis_4_4, 'Ensure VPC subnets are not overly permissive', high)
cis_control(cis_4_5, 'Use private subnets for databases', high)
cis_control(cis_4_6, 'Enable NACLs on private subnets', medium)

cis_control(cis_5_1, 'Enable GuardDuty in all regions', high)
cis_control(cis_5_2, 'Enable Security Hub in all regions', medium)
cis_control(cis_5_3, 'Enable Config in all regions', medium)
cis_control(cis_5_4, 'Enable Macie for S3 data discovery', medium)

cis_control(cis_6_1, 'Ensure RDS instances are not publicly accessible', critical)
cis_control(cis_6_2, 'Enable DynamoDB encryption at rest', high)
cis_control(cis_6_3, 'Enable ElastiCache encryption at rest', medium)
cis_control(cis_6_4, 'Restrict DynamoDB access to specific VPCs', medium)
cis_control(cis_6_5, 'Enable RDS enhanced monitoring', medium)
cis_control(cis_6_6, 'Enable Neptune encryption', high)

cis_control(cis_7_1, 'Ensure EC2 instances are not publicly accessible', critical)
cis_control(cis_7_2, 'Use IMDSv2 on EC2 instances', high)
cis_control(cis_7_3, 'Enable EC2 instance detailed monitoring', medium)
cis_control(cis_7_4, 'Ensure Lambda functions use latest runtime', medium)
cis_control(cis_7_5, 'Restrict Lambda execution role to minimum permissions', high)

cis_severity(critical, 4)
cis_severity(high, 3)
cis_severity(medium, 2)
cis_severity(low, 1)

% ── AWS IAM Best Practices ──

violates_separation_of_duties($user) IF
    user($user) AND has_permission($user, deploy_code) AND has_permission($user, approve_deploy)

violates_separation_of_duties($user) IF
    user($user) AND has_permission($user, create_role) AND has_permission($user, assign_role)

excessive_permissions($user, $count) IF
    user($user) AND permission_count($user, $count) AND $count > 15

stale_access($user) IF
    user($user) AND is_active($user) AND last_login_days($user, $days) AND $days > 90

unused_permission($user, $perm) IF
    user($user) AND has_permission($user, $perm) AND last_used_days($perm, $days) AND $days > 30

cross_account_risk($user) IF
    user($user) AND has_role($user, $role) AND cross_account_role($role) AND NOT mfa_enabled($user)

privilege_escalation_risk($user) IF
    user($user) AND has_permission($user, attach_user_policy) AND has_permission($user, create_access_key)

privilege_escalation_risk($user) IF
    user($user) AND has_permission($user, put_role_policy) AND has_permission($user, assume_role)

root_violation(root_account, has_access_keys) IF
    iam_user(root_account) AND role(root_account, root) AND has_access_key(root_account)

root_violation(root_account, no_mfa) IF
    iam_user(root_account) AND role(root_account, root) AND NOT mfa_enabled(root_account)

service_account_risk($user) IF
    user($user) AND account_type($user, service) AND has_console_access($user)

service_account_risk($user) IF
    user($user) AND account_type($user, service) AND NOT rotate_keys_90d($user)

admin_boundary_violation($user) IF
    user($user) AND has_permission($user, manage_users) AND has_permission($user, manage_billing)

admin_boundary_violation($user) IF
    user($user) AND has_permission($user, manage_users) AND has_permission($user, create_invoice)

wildcard_risk($user) IF
    user($user) AND has_wildcard_permission($user, $perm)


% ───────────────────────────────────────────────────────────────
% Layer 2: Policies
% ───────────────────────────────────────────────────────────────

% ── Role Hierarchy ──

role(intern)
role(junior_dev)
role(mid_senior_dev)
role(senior_dev)
role(tech_lead)
role(eng_manager)
role(director)
role(vp_engineering)
role(cto)

role(helpdesk)
role(sysadmin)
role(security_analyst)
role(security_engineer)
role(devops_engineer)

role(product_manager)
role(business_analyst)

inherits(junior_dev, intern)
inherits(mid_senior_dev, junior_dev)
inherits(senior_dev, mid_senior_dev)
inherits(tech_lead, senior_dev)
inherits(eng_manager, tech_lead)
inherits(director, eng_manager)
inherits(vp_engineering, director)
inherits(cto, vp_engineering)

inherits(sysadmin, helpdesk)
inherits(security_engineer, security_analyst)
inherits(devops_engineer, sysadmin)

department_role(engineering, junior_dev)
department_role(engineering, mid_senior_dev)
department_role(engineering, senior_dev)
department_role(engineering, tech_lead)
department_role(engineering, eng_manager)
department_role(engineering, director)
department_role(engineering, vp_engineering)
department_role(engineering, cto)

department_role(operations, helpdesk)
department_role(operations, sysadmin)
department_role(operations, devops_engineer)

department_role(security, security_analyst)
department_role(security, security_engineer)

department_role(product, product_manager)
department_role(product, business_analyst)

role_has_permission($role, $perm) IF role_permission($role, $perm)
role_has_permission($role, $perm) IF inherits($role, $parent) AND role_has_permission($parent, $perm)

user_has_permission($user, $perm) IF user($user) AND has_role($user, $role) AND role_has_permission($role, $perm)

deploy_role_level(intern, 0)
deploy_role_level(junior_dev, 1)
deploy_role_level(mid_senior_dev, 2)
deploy_role_level(senior_dev, 3)
deploy_role_level(tech_lead, 4)
deploy_role_level(eng_manager, 5)
deploy_role_level(director, 6)
deploy_role_level(vp_engineering, 7)
deploy_role_level(cto, 8)

role_level($role, $level) IF deploy_role_level($role, $level)
role_level($role, $level) IF inherits($role, $parent) AND role_level($parent, $parent_level) AND $level = $parent_level + 1

% ── Environment Tiers ──

environment(production, tier_1, highest_security)
environment(golden, tier_1, highest_security)
environment(staging, tier_2, high_security)
environment(development, tier_3, standard_security)
environment(sandbox, tier_4, minimal_security)

deploy_requires_level(production, 6)
deploy_requires_level(golden, 6)
deploy_requires_level(staging, 4)
deploy_requires_level(development, 2)
deploy_requires_level(sandbox, 1)

requires_encryption(production)
requires_encryption(golden)
requires_encryption(staging)

requires_backup(production)
requires_backup(golden)

allows_public_access(sandbox)
allows_public_access(development)

requires_audit_log(production)
requires_audit_log(golden)
requires_audit_log(staging)

can_access_tier($user, $env) IF user($user) AND has_role($user, $role) AND deploy_requires_level($env, $min_level) AND deploy_role_level($role, $level) AND $level >= $min_level

can_deploy($user, $env) IF user($user) AND has_role($user, $role) AND deploy_requires_level($env, $min_level) AND deploy_role_level($role, $level) AND $level >= $min_level AND user_has_permission($user, deploy_code)

% ── Data Classification ──

classification(public, 1, no_restrictions)
classification(internal, 2, need_to_know)
classification(confidential, 3, nda_required)
classification(secret, 4, top_secret_clearance)

role_clearance(intern, public)
role_clearance(junior_dev, internal)
role_clearance(helpdesk, internal)
role_clearance(business_analyst, internal)
role_clearance(product_manager, internal)
role_clearance(mid_senior_dev, confidential)
role_clearance(sysadmin, confidential)
role_clearance(security_analyst, confidential)
role_clearance(senior_dev, confidential)
role_clearance(tech_lead, confidential)
role_clearance(security_engineer, secret)
role_clearance(devops_engineer, confidential)
role_clearance(eng_manager, confidential)
role_clearance(director, secret)
role_clearance(vp_engineering, secret)
role_clearance(cto, secret)

user_clearance($user, $level) IF user($user) AND has_role($user, $role) AND role_clearance($role, $cls) AND classification($cls, $level, _)

user_max_clearance($user, $max_level) IF
    user($user) AND has_role($user, $role) AND role_clearance($role, $cls) AND classification($cls, $max_level, _)

can_access_resource($user, $resource) IF
    user($user) AND resource($resource, _, _, _, _, $res_class) AND classification($res_class, $res_level, _) AND user_max_clearance($user, $user_level) AND $user_level >= $res_level

clearance_violation($user, $resource) IF
    user($user) AND resource($resource, _, _, _, _, $res_class) AND classification($res_class, $res_level, _) AND user_max_clearance($user, $user_level) AND $user_level < $res_level

% ── Access Control Rules ──

role_permission(intern, read_code)
role_permission(junior_dev, read_code)
role_permission(junior_dev, write_code)
role_permission(junior_dev, run_tests)
role_permission(mid_senior_dev, read_code)
role_permission(mid_senior_dev, write_code)
role_permission(mid_senior_dev, run_tests)
role_permission(mid_senior_dev, review_code)
role_permission(senior_dev, read_code)
role_permission(senior_dev, write_code)
role_permission(senior_dev, run_tests)
role_permission(senior_dev, review_code)
role_permission(senior_dev, merge_pr)
role_permission(tech_lead, read_code)
role_permission(tech_lead, write_code)
role_permission(tech_lead, run_tests)
role_permission(tech_lead, review_code)
role_permission(tech_lead, merge_pr)
role_permission(tech_lead, deploy_code)

role_permission(helpdesk, read_logs)
role_permission(helpdesk, reset_password)
role_permission(helpdesk, view_tickets)
role_permission(sysadmin, read_logs)
role_permission(sysadmin, manage_users)
role_permission(sysadmin, manage_servers)
role_permission(sysadmin, access_database)
role_permission(devops_engineer, read_logs)
role_permission(devops_engineer, manage_servers)
role_permission(devops_engineer, deploy_code)
role_permission(devops_engineer, manage_ci_cd)
role_permission(devops_engineer, manage_infrastructure)

role_permission(security_analyst, read_logs)
role_permission(security_analyst, view_audit)
role_permission(security_analyst, scan_vulnerabilities)
role_permission(security_engineer, read_logs)
role_permission(security_engineer, view_audit)
role_permission(security_engineer, scan_vulnerabilities)
role_permission(security_engineer, manage_firewall)
role_permission(security_engineer, manage_encryption)
role_permission(security_engineer, rotate_keys)

role_permission(eng_manager, manage_team)
role_permission(eng_manager, approve_pto)
role_permission(eng_manager, view_budget)
role_permission(director, manage_team)
role_permission(director, approve_pto)
role_permission(director, view_budget)
role_permission(director, approve_budget)
role_permission(director, manage_department)
role_permission(vp_engineering, manage_department)
role_permission(vp_engineering, approve_budget)
role_permission(vp_engineering, view_financials)
role_permission(vp_engineering, manage_directors)
role_permission(cto, manage_all_engineering)
role_permission(cto, approve_budget)
role_permission(cto, view_financials)
role_permission(cto, manage_directors)
role_permission(cto, set_policy)

role_permission(product_manager, view_analytics)
role_permission(product_manager, manage_backlog)
role_permission(product_manager, approve_features)
role_permission(business_analyst, view_analytics)
role_permission(business_analyst, create_reports)

critical_operation(delete_data)
critical_operation(manage_production)
critical_operation(access_secret_data)
critical_operation(modify_security_group)
critical_operation(manage_encryption_keys)

can_perform_critical($user, $op) IF user($user) AND user_has_permission($user, $op) AND has_role($user, $role) AND deploy_role_level($role, $level) AND $level >= 6

can_access_database($user) IF user($user) AND user_has_permission($user, access_database)

production_db_access($user) IF user($user) AND can_access_database($user) AND has_role($user, $role) AND deploy_role_level($role, $level) AND $level >= 5

% ── Approval Workflows ──

requires_approval(deploy_production, director, 7)
requires_approval(deploy_golden, director, 7)
requires_approval(manage_production, vp_engineering, 30)
requires_approval(access_secret_data, security_engineer, 1)
requires_approval(modify_security_group, security_engineer, 3)
requires_approval(manage_encryption_keys, security_engineer, 1)
requires_approval(delete_data, director, 1)
requires_approval(manage_users, sysadmin, 30)

approval_chain($op, $approver_role) IF requires_approval($op, $approver_role, _)

self_approve_allowed($user, $op) IF
    user($user) AND has_role($user, $role) AND requires_approval($op, $approver_role, _) AND inherits($role, $approver_role)

has_approver_clearance($role, $approver_role) IF inherits($role, $approver_role)
has_approver_clearance($role, $approver_role) IF inherits($role, $parent) AND has_approver_clearance($parent, $approver_role)

can_self_approve($user, $op) IF
    user($user) AND has_role($user, $role) AND requires_approval($op, $approver_role, _) AND has_approver_clearance($role, $approver_role)

requires_mfa(deploy_production)
requires_mfa(deploy_golden)
requires_mfa(access_secret_data)
requires_mfa(manage_encryption_keys)
requires_mfa(manage_users)
requires_mfa(modify_security_group)

compliant_deployment($user, $env) IF
    user($user) AND can_deploy($user, $env) AND has_role($user, $role) AND deploy_requires_level($env, $min_level) AND deploy_role_level($role, $level) AND $level >= $min_level + 1

non_compliant_deployment($user, $env) IF
    user($user) AND user_has_permission($user, deploy_code) AND has_role($user, $role) AND deploy_requires_level($env, $min_level) AND deploy_role_level($role, $level) AND $level < $min_level

incident_mode(active)

restricted_during_incident($user) IF
    user($user) AND incident_mode(active) AND has_role($user, $role) AND deploy_role_level($role, $level) AND $level < 5


